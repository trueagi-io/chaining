;;;;;;;;;;;;;;;;;;;;;;;;;;;;;
;; Function call evaluator ;;
;;;;;;;;;;;;;;;;;;;;;;;;;;;;;

;; Evaluate any function call prefixed by a bang
(exec (5 * main)
      (, (! $fx) (= $fx $bdy))
      (O (- (! $fx)) (+ $bdy)))

;;;;;;;;;;
;; Main ;;
;;;;;;;;;;

;; Test backward chainer
;; (! (bc Z (: $a (→ $b (→ 𝜑 (→ 𝜓 𝜑))))))
(! (bc (S (S (S (S Z)))) . (: $x (→ 𝜑 (→ 𝜓 𝜑)))))
